SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
DOCTOR_PASSWORD=your-doctor-password
ADMIN_PASSWORD=your-admin-password
JWT_SECRET=generate-a-long-random-string-e.g.-openssl-rand-hex-32
JWT_EXPIRY_HOURS=12

# Minimum doctor-feedback labels required before retraining is allowed
RETRAIN_MIN_SAMPLES=25

# In production set this to your deployed frontend origin (no trailing slash),
# e.g. https://your-app.vercel.app
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost

# --- Production VM only (used by docker-compose.prod.yml / Caddy) ---
# Public domain that points (A record) to the VM's public IP
DOMAIN=api.your-domain.com
# Email for Let's Encrypt certificate notifications
ACME_EMAIL=you@your-domain.com
